{
  "name": "@openacp/teams-adapter",
  "version": "1.0.0",
  "description": "Teams adapter plugin for OpenACP — Adaptive Cards, commands, streaming",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
