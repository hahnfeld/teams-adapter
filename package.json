    "@microsoft/teams.apps": "^2.0.0",
    "@microsoft/teams.botbuilder": "^2.0.0",
    "adaptivecards-templating": "^2.3.1"
  },
  "devDependencies": {
    "@openacp/plugin-sdk": "^2026.331.1",
    "typescript": "^5.4.0",
